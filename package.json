{
  "name": "3d-smarthome-converter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": "src/main.js",
  "scripts": {
    "dev": "node src/main.js",
    "build:pkg": "pkg . --out-path dist"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.1.1",
    "@gltf-transform/functions": "^4.1.1",
    "chokidar": "^3.6.0",
    "obj2gltf": "^3.1.6",
    "unzipper": "^0.12.3"
  },
  "pkg": {
    "assets": [
      "src/blender_convert.py"
    ],
    "targets": [
      "node20-win-x64",
      "node20-linux-x64",
      "node20-macos-x64",
      "node20-macos-arm64"
    ],
    "outputPath": "dist"
  }
}
